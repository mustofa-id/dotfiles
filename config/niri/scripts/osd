#!/usr/bin/env bash

MODE="${1:-sink}"

ID_FILE="/tmp/osd-$MODE.id"
TIMEOUT=3000

# drain stdin only if piped
[[ -p /dev/stdin ]] && cat >/dev/null

source ~/.config/niri/scripts/utils

case "$MODE" in
  sink)
    NODE="@DEFAULT_AUDIO_SINK@"
    TITLE="Volume"

    INFO=$(wpctl get-volume "$NODE")
    VOL=$(echo "$INFO" | awk '{printf "%d", $2 * 100}')

    if echo "$INFO" | grep -q MUTED; then
      notify_replace title="¾░Ėł $TITLE ${VOL}% (Muted)" progress=$VOL
    else
      notify_replace title="¾░ĢŠ $TITLE ${VOL}%" progress=$VOL
    fi
    ;;
  source)
    NODE="@DEFAULT_AUDIO_SOURCE@"
    TITLE="Microphone"

    INFO=$(wpctl get-volume "$NODE")
    VOL=$(echo "$INFO" | awk '{printf "%d", $2 * 100}')

    if echo "$INFO" | grep -q MUTED; then
      notify_replace title="¾░ŹŁ $TITLE ${VOL}% (Muted)" progress=$VOL
    else
      notify_replace title="¾░Ź¼ $TITLE ${VOL}%" progress=$VOL
    fi
    ;;
  brightness)
    CUR=$(brightnessctl get)
    MAX=$(brightnessctl max)
    PCT=$(( CUR * 100 / MAX ))

    notify_replace title="ŌśĆ Brightness ${PCT}%" progress=$PCT
    ;;
  *)
    exit 0
    ;;
esac
