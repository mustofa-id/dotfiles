#!/usr/bin/env bash

pid=$(pgrep -x wf-recorder)
icon="$HOME/.config/assets/ic-screen-record.svg"

# -------- STOP --------
if [ -n "$pid" ]; then
    kill -INT "$pid"
    notify-send -a "WFR" -i $icon "Screen Recorder" "Recording stopped"
    exit 0
fi

# -------- DIALOG --------
input=$(zenity --forms \
    --title="Run WF-Recorder" \
    --text="Recording settings" \
    --add-combo="Mode" \
    --combo-values="Region|Fullscreen" \
    --add-combo="Audio" \
    --combo-values="No Audio|System Sound|Microphone" \
    --add-combo="Format" \
    --combo-values="MP4|MKV")

# user cancelled
[ $? -ne 0 ] && exit 1
[ -z "$input" ] && exit 1

# -------- SAFE PARSING --------
mode=$(echo "$input" | awk -F'|' '{print $1}' | xargs)
audio_choice=$(echo "$input" | awk -F'|' '{print $2}' | xargs)
fmt=$(echo "$input" | awk -F'|' '{print $3}' | xargs | tr '[:upper:]' '[:lower:]')

# -------- OUTPUT --------
outfile="$HOME/Videos/Screencast_$(date +%Y%m%d_%H%M%S).${fmt:-mp4}"

# -------- REGION / FULLSCREEN --------
output_args=()

case "$mode" in
    "Region")
        region=$(slurp 2>/dev/null | tr -d '\n')
        [ -z "$region" ] && exit 1
        output_args=(-g "$region")
        ;;
    "Fullscreen")
        output_args=(-o "$(niri msg --json focused-output | jq -r .name)")
        ;;
esac

# -------- AUDIO --------
audio_args=()
case "$audio_choice" in
    "System Sound")
        audio_source=$(pactl list short sources | awk '/monitor/ {print $2; exit}')
        [ -n "$audio_source" ] && audio_args=(--audio="$audio_source")
        ;;
    "Microphone")
        audio_source=$(pactl info | awk -F': ' '/Default Source/ {print $2}')
        [ -n "$audio_source" ] && audio_args=(--audio="$audio_source")
        ;;
    "No Audio")
        audio_args=()
        ;;
esac

# -------- RECORD --------
wf-recorder "${output_args[@]}" "${audio_args[@]}" -f "$outfile" &

notify-send -a "WFR" -i $icon "Screen Recorder" "Started recording in '$mode' mode using '$audio_choice' audio in '${fmt^^}' format."
