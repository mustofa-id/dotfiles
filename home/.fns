#!/usr/bin/env bash

ffmpeg_soc_hd() {
  input="$1"
  output="${input%.*}-hd.mp4"

  ffmpeg -i "$input" \
    -hide_banner \
    -loglevel error \
    -stats \
    -movflags +faststart \
    -vf "scale=1080:-2:flags=lanczos,fps=30" \
    -r 30 \
    -c:v libx264 -profile:v high -level 4.1 -pix_fmt yuv420p \
    -crf 20 -maxrate 6M \
    -c:a aac -b:a 128k -ar 48000 -ac 2 \
    "$output"
}

ffmpeg_soc_hd_img() {
  local input="$1"
  local output="${input%.*}-hd.jpg"

  ffmpeg -i "$input" \
    -frames:v 1 \
    -vf scale=2560:-2:flags=lanczos \
    -q:v 2 \
    -map_metadata -1 \
    "$output"
}

charging_limit() {
  local input=${1:-79}
  local path="/sys/class/power_supply/BAT0/charge_control_end_threshold"

  # Check if sysfs path exists
  if [[ ! -f "$path" ]]; then
    echo "[ERROR] Battery control file not found: $path"
    return 1
  fi

  # Validate numeric input
  if ! [[ "$input" =~ ^[0-9]+$ ]]; then
    echo "[ERROR] Invalid input: '$input' (must be a number)"
    return 1
  fi

  # Validate range (typical safe range 50–100)
  if (( input < 79 || input > 100 )); then
    echo "[ERROR] Invalid range: ${input}% (allowed: 79-100)"
    return 1
  fi

  # Read current value
  local current
  current=$(cat "$path" 2>/dev/null)

  echo "[INFO] Current charging limit: ${current}%"
  echo "[INFO] Setting new charging limit to: ${input}%"

  # Apply new value
  echo "$input" | sudo tee "$path" > /dev/null

  echo "[OK] Charging limit updated to ${input}%"
}

filebrowser_exp_def() {
  filebrowser -r "$1" \
    -d ~/Personal/Scripts/filebrowser.db \
    -a 0.0.0.0
}

rdp_con() {
  local host="127.0.0.1"
  local user="mstf"

  while getopts "h:u:" opt; do
    case "$opt" in
      h) host="$OPTARG" ;;
      u) user="$OPTARG" ;;
      *) echo "Usage: rdp_con [-h host] [-u user]" && return 1 ;;
    esac
  done

  xfreerdp3 /v:"$host" \
    /u:"$user" /d:. \
    /log-level:WARN \
    /f \
    /clipboard \
    /sound /gfx /bpp:32
}

toggle_mako_dnd() {
    # Check current mode
    current_mode=$(makoctl mode)

    if [[ "$current_mode" == "dnd" ]]; then
        # Switch back to default
        makoctl mode -r dnd
        echo "Mako: DND disabled"
    else
        # Enable DND
        makoctl mode -a dnd
        echo "Mako: DND enabled"
    fi
}
